{
  "manifest_version": 3,
  "name": "Xync Agent Setter",
  "version": "1.1.0",
  "description": "Connect your own Bybit or HTX account to Xync as a trading agent, with your consent.",
  "homepage_url": "https://xync.net",
  "minimum_chrome_version": "102",
  "permissions": ["activeTab", "cookies", "webRequest", "storage"],
  "host_permissions": [
    "https://www.bybit.com/*",
    "https://www.htx.com/*",
    "https://api.xync.net/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Xync Agent Setter",
    "default_icon": {
      "16": "ico/icon16.png",
      "32": "ico/icon32.png",
      "48": "ico/icon48.png",
      "128": "ico/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "ico/icon16.png",
    "32": "ico/icon32.png",
    "48": "ico/icon48.png",
    "128": "ico/icon128.png"
  }
}
